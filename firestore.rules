rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 商品・コレクション: 読み取りは全員OK、書き込みは認証済みのみ
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /collections/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
